        </mxCell>
        <mxCell id="HVi_0dQcPSTtkjVWcyo2-22" parent="WIyWlLk6GJQsqaUBKTNV-1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d80073;fontColor=#ffffff;strokeColor=#A50040;fontSize=16;fontStyle=1" value="Outputs ready for Babelbrain" vertex="1">
          <mxGeometry height="80" width="210" x="80" y="1070" as="geometry" />
        </mxCell>
        <mxCell id="HVi_0dQcPSTtkjVWcyo2-26" parent="WIyWlLk6GJQsqaUBKTNV-1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;horizontal=1;verticalAlign=top;spacingLeft=0;spacingBottom=0;spacingRight=10;fontStyle=0" value="&lt;ul&gt;&lt;li&gt;Step 1: Converts raw MRI data from scanner DICOM format to standardized NIfTI files and initializes the subject analysis directory.&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Step 2: Identifies anatomical scans (T1, T2, PETRA), standardizes filenames, and organizes them into the pipeline’s subject-level analysis structure.&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Step 3: Resamples anatomical images to a uniform &lt;span data-start=&quot;846&quot; data-end=&quot;875&quot;&gt;1 mm isotropic resolution&lt;/span&gt; to ensure compatibility with downstream modeling tools.&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="340" width="270" x="320" y="110" as="geometry" />
        </mxCell>
        <mxCell id="HVi_0dQcPSTtkjVWcyo2-27" parent="WIyWlLk6GJQsqaUBKTNV-1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;horizontal=1;verticalAlign=top;spacingLeft=0;spacingBottom=0;spacingRight=10;fontStyle=0" value="&lt;ul&gt;&lt;li&gt;Step 4: Runs &lt;span data-start=&quot;988&quot; data-end=&quot;1005&quot;&gt;SimNIBS CHARM&lt;/span&gt; to generate an individualized head model including tissue segmentations and anatomical reference volumes.&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="100" width="270" x="320" y="470" as="geometry" />
        </mxCell>
        <mxCell id="HVi_0dQcPSTtkjVWcyo2-28" parent="WIyWlLk6GJQsqaUBKTNV-1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;horizontal=1;verticalAlign=top;spacingLeft=0;spacingBottom=0;spacingRight=10;fontStyle=0" value="&lt;ul&gt;&lt;li&gt;Step 5: Generates subject-specific target masks from predefined MNI coordinates or masks using inverse normalization.&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="100" width="270" x="320" y="590" as="geometry" />
        </mxCell>
        <mxCell id="HVi_0dQcPSTtkjVWcyo2-29" parent="WIyWlLk6GJQsqaUBKTNV-1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;horizontal=1;verticalAlign=top;spacingLeft=0;spacingBottom=0;spacingRight=10;fontStyle=0" value="&lt;ul&gt;&lt;li&gt;Step 6: Evaluates T1–T2 alignment (if T2 used) by computing difference images and summary statistics for visual and quantitative QC&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="100" width="270" x="320" y="710" as="geometry" />
        </mxCell>
        <mxCell id="HVi_0dQcPSTtkjVWcyo2-30" parent="WIyWlLk6GJQsqaUBKTNV-1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;horizontal=1;verticalAlign=top;spacingLeft=0;spacingBottom=0;spacingRight=10;fontStyle=0" value="&lt;ul&gt;&lt;li&gt;Step 7: Converts PETRA into a &lt;span data-start=&quot;1507&quot; data-end=&quot;1520&quot; style=&quot;&quot;&gt;pseudo-CT using UCL&#39;s petra-to-ct toolbox.&amp;nbsp;&lt;/span&gt;&amp;nbsp;to improve skull modeling for ultrasound propagation simulations.&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Step 8: Computes optimal ultrasound transducer entry points on the scalp for each target region using geometric and distance constraints using the TUS-entry toolbox by Atkinson-Clement &amp;amp; Kaiser&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="220" width="270" x="320" y="830" as="geometry" />
        </mxCell>
