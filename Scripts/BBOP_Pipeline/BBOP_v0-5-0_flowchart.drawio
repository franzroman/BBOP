        <mxCell id="HVi_0dQcPSTtkjVWcyo2-19" parent="WIyWlLk6GJQsqaUBKTNV-1" style="rounded=0;whiteSpace=wrap;html=1;" value="Step 8 (opt)&lt;br&gt;TUS-entry optimization&lt;div&gt;TUS-entry Toolbox&lt;/div&gt;" vertex="1">
